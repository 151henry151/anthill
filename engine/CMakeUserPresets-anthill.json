{
	"version": 4,
	"cmakeMinimumRequired": {
		"major": 3,
		"minor": 22,
		"patch": 0
	},
	"configurePresets": [
		{
			"name": "anthill-engine",
			"displayName": "Anthill engine (Luanti 5.10 + patch)",
			"description": "Out-of-tree binaryDir under the Anthill repo; set ANTHILL_INSTALL_PREFIX before configure (build.sh exports it).",
			"inherits": "RelWithDebInfo",
			"generator": "Unix Makefiles",
			"binaryDir": "${fileDir}/../../engine/out/build",
			"cacheVariables": {
				"CMAKE_INSTALL_PREFIX": "$env{ANTHILL_INSTALL_PREFIX}",
				"BUILD_CLIENT": "ON",
				"BUILD_SERVER": "OFF",
				"RUN_IN_PLACE": "FALSE"
			}
		}
	],
	"buildPresets": [
		{
			"name": "anthill-engine",
			"configurePreset": "anthill-engine",
			"jobs": 0
		}
	]
}
