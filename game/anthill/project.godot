; Anthill — Godot voxel prototype
config_version=5

[application]
config/name="Anthill"
config/description="Grain-scale voxel colony: top-down view; sand physics; future food, queen, and colony policy — not direct ant control."
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.2", "GL Compatibility")
run/max_fps=60

[display]
window/vsync/vsync_mode=1

[physics]
common/physics_ticks_per_second=30

[rendering]

renderer/rendering_method="gl_compatibility"
textures/canvas_textures/default_texture_filter=0
